
PostgreSQL_DATABASE_URL=YOUR_DATABASE_URL_HERE
# 火山方舟 OpenAI SDK 兼容模式
ARK_API_KEY=YOUR_API_KEY_HERE
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_MODEL_TEXT=doubao-seed-2-0-lite-260215
VOLC_MODEL_IMAGE=doubao-seedream-5-0-260128
Client_Port = 4000
Server_Port = 4001
ACCESS_TOKEN_SECRET=replace_with_at_least_32_random_characters
REFRESH_TOKEN_SECRET=replace_with_a_different_32_character_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
GNEWS_API_KEY=

# RustFS（S3 兼容对象存储）。留空时继续使用 server/uploads 本地存储。
RUSTFS_ENDPOINT=http://127.0.0.1:9000
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=123456
RUSTFS_BUCKET=bytedance-train
RUSTFS_REGION=us-east-1
RUSTFS_FORCE_PATH_STYLE=true
# 浏览器可访问的桶/CDN 地址，例如 https://assets.example.com/bytedance-train
RUSTFS_PUBLIC_URL=http://localhost:9000/bytedance-train
